# ============================================================
# ToolsBar v2 — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://toolsbar.com

# ── Database (Supabase PostgreSQL) ───────────────────────────
DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# ── Supabase (file storage for blog images) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Admin Auth ───────────────────────────────────────────────
NEXTAUTH_SECRET=your-very-long-random-secret-here-minimum-32-chars
ADMIN_INITIAL_PASSWORD=ChangeMe@2025!

# ── URL Shortener (Cloudflare Worker) ────────────────────────
# Your existing worker — only used by the URL Shortener tool.
URL_SHORTENER_WORKER_URL=https://url.kazirajibulislam567567.workers.dev

# ── PDF Split ─────────────────────────────────────────────────
# No external backend needed. PDF splitting is handled by the
# built-in Next.js API route at /api/pdf/split using pdf-lib.
# Nothing to configure here.

# ── Google AdSense (add after approval) ──────────────────────
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_AD_SLOT_HOME_HERO=XXXXXXXXXX
NEXT_PUBLIC_AD_SLOT_HOME_MID=XXXXXXXXXX
NEXT_PUBLIC_AD_SLOT_TOOL_BELOW=XXXXXXXXXX
NEXT_PUBLIC_AD_SLOT_BLOG_SIDEBAR=XXXXXXXXXX
NEXT_PUBLIC_AD_SLOT_BLOG_CONTENT=XXXXXXXXXX

# ── Contact Form (Formspree) ─────────────────────────────────
NEXT_PUBLIC_FORMSPREE_ID=your-formspree-form-id

# ── Analytics (optional) ─────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
